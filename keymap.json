[
  //--- Workspace
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-p": "command_palette::Toggle",
      "alt-s": "terminal_panel::ToggleFocus",
      "ctrl-f": "buffer_search::Deploy",
      
      // Zed
      "ctrl-,": "zed::OpenSettingsFile",
      "ctrl-shift-k": "zed::OpenKeymapFile",
      "ctrl-shift-x": "zed::Extensions",
      
      // Project
      "shift-z": "projects::OpenRecent",
      "alt-a": "project_panel::ToggleFocus",
      "ctrl-o": ["projects::OpenRecent", { "create_new_window": false }],
      "ctrl-shift-o": [ // revisar
        "projects::OpenRemote",
        { "from_existing_connection": false, "create_new_window": false },
      ],
      "alt-ctrl-shift-o": [ // revisar
        "projects::OpenRemote",
        { "from_existing_connection": false, "create_new_window": false },
      ],
      
      // Agent
      "alt-d": "agent::ToggleFocus",
      "alt-t": "agent::NewTextThread",
      
      // Pane
      "ctrl-shift-t": "pane::ReopenClosedItem",
      "alt-i": "pane::SplitAndMoveUp",
      "alt-k": "pane::SplitAndMoveDown",
      "alt-j": "pane::SplitAndMoveLeft",
      "alt-l": "pane::SplitAndMoveRight",
      
      // Workspace
      "ctrl-s": "workspace::Save",
      "ctrl-shift-s": "workspace::SaveAs",
      "ctrl-shift-n": "workspace::NewWindow",
      "shift-j": "workspace::ActivatePaneLeft",
      "shift-i": "workspace::ActivatePaneUp",
      "shift-k": "workspace::ActivatePaneDown",
      "shift-l": "workspace::ActivatePaneRight",
      "shift-t": "workspace::NewTerminal",
      "alt-q": "workspace::ToggleLeftDock",
      "alt-w": "workspace::ToggleBottomDock",
      "alt-e": "workspace::ToggleRightDock",
      "shift-f": "workspace::NewFile",
      "alt-1": ["workspace::ActivatePane", 0],
      "alt-2": ["workspace::ActivatePane", 1],
      "alt-3": ["workspace::ActivatePane", 2],
      "alt-4": ["workspace::ActivatePane", 3],
      "alt-5": ["workspace::ActivatePane", 4],
      "alt-6": ["workspace::ActivatePane", 5],
      "alt-7": ["workspace::ActivatePane", 6],
      "alt-8": ["workspace::ActivatePane", 7],
      "alt-9": ["workspace::ActivatePane", 8],
    },
  },
  {
    "context": "Workspace && debugger_stopped",
    "bindings": {
      "f5": "debugger::Continue",
    },
  },
  //--- Pane
  {
    "context": "Pane",
    "bindings": {
      "shift-1": ["pane::ActivateItem", 0],
      "shift-2": ["pane::ActivateItem", 1],
      "shift-3": ["pane::ActivateItem", 2],
      "shift-4": ["pane::ActivateItem", 3],
      "shift-5": ["pane::ActivateItem", 4],
      "shift-6": ["pane::ActivateItem", 5],
      "shift-7": ["pane::ActivateItem", 6],
      "shift-8": ["pane::ActivateItem", 7],
      "shift-9": ["pane::ActivateItem", 8],
      
      "alt-x": ["pane::CloseActiveItem", { "close_pinned": false }],
      "alt-c": ["pane::CloseCleanItems", { "close_pinned": false }],
      "alt-shift-x": ["pane::CloseOtherItems", { "close_pinned": false }],
    },
  },
  //--- Editor
  {
    "context": "Editor",
    "bindings": {
      // Actions
      "f2": "editor::Rename",
      "ctrl-x": "editor::Cut",
      "ctrl-c": "editor::Copy",
      "ctrl-v": "editor::Paste",
      "ctrl-z": "editor::Undo",
      "ctrl-y": "editor::Redo",
      "ctrl-_": "editor::ToggleFold",
      "ctrl-space": "editor::ShowCompletions",
      
      "tab": "editor::Tab",
      "shift-tab": "editor::Backtab",
      "ctrl-shift-i": "editor::Format",
      "ctrl-shift-c": ["editor::ToggleComments", { "advance_downwards": true }],
      
      // Movement
      "up": "editor::MoveUp",
      "down": "editor::MoveDown",
      "left": "editor::MoveLeft",
      "right": "editor::MoveRight",
      
      "end": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "home": [
        "editor::MoveToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      
      "ctrl-left": "editor::MoveToPreviousWordStart",
      "ctrl-right": "editor::MoveToNextWordEnd",
      "ctrl-home": "editor::MoveToBeginning",
      "ctrl-end": "editor::MoveToEnd",
      
      "pageup": "editor::MovePageUp",
      "alt-pageup": "editor::PageUp",
      "pagedown": "editor::MovePageDown",
      "alt-pagedown": "editor::PageDown",
      
      "alt-shift-up": "editor::MoveLineUp",
      "alt-shift-down": "editor::MoveLineDown",
      
      // Scroll
      "ctrl-up": "editor::LineUp",
      "ctrl-down": "editor::LineDown",
      
      // Remove
      "escape": "editor::Cancel",
      "delete": "editor::Delete",
      "backspace": "editor::Backspace",
      "shift-backspace": "editor::DeleteLine",
      "ctrl-delete": "editor::DeleteToNextWordEnd",
      "ctrl-backspace": "editor::DeleteToPreviousWordStart",
      
      // Carret
      "alt-up": "editor::AddSelectionAbove", // Insert Cursor Above
      "alt-down": "editor::AddSelectionBelow", // Insert Cursor Below
      
      // Line
      "ctrl-shift-up": "editor::DuplicateLineUp",
      "ctrl-shift-down": "editor::DuplicateLineDown",
      
      // Selection
      "shift-up": "editor::SelectUp",
      "shift-down": "editor::SelectDown",
      "shift-left": "editor::SelectLeft",
      "shift-right": "editor::SelectRight",
      
      "ctrl-shift-left": "editor::SelectToPreviousWordStart",
      "ctrl-shift-right": "editor::SelectToNextWordEnd",
      "ctrl-shift-home": "editor::SelectToBeginning",
      "ctrl-shift-end": "editor::SelectToEnd",
      
      "shift-pageup": "editor::SelectPageUp",
      "shift-pagedown": "editor::SelectPageDown",
      
      "ctrl-a": "editor::SelectAll",
      
      "shift-home": [
        "editor::SelectToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "shift-end": [
        "editor::SelectToEndOfLine",
        { "stop_at_soft_wraps": true },
      ],
    },
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "enter": "editor::Newline",
      "ctrl-enter": "editor::NewlineAbove",
      "shift-enter": "editor::NewlineBelow",
      
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-r": "buffer_search::DeployReplace",
      
      "alt-.": "agent::AddSelectionToThread",
      "alt-enter": "editor::ToggleCodeActions",
      
      "ctrl-g": "go_to_line::Toggle",
    },
  },
  {
    "context": "Editor && mode == full && edit_prediction",
    "bindings": {},
  },
  {
    "context": "Editor && mode == auto_height",
    "bindings": {
      "ctrl-enter": "editor::Newline",
      "shift-enter": "editor::NewlineBelow",
    },
  },
  {
    "context": "Editor && renaming",
    "bindings": {
      "enter": "editor::ConfirmRename",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "tab": "editor::ConfirmCompletionReplace",
      "enter": "editor::ConfirmCompletion",
    },
  },
  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "up": "editor::ContextMenuPrevious",
      "down": "editor::ContextMenuNext",
      "pageup": "editor::ContextMenuFirst",
      "pagedown": "editor::ContextMenuLast",
    },
  },
  //-- Languaje specific
  {
    "context": "Editor && !extension",
    "bindings": {
      "alt-enter": "language_selector::Toggle",
    },
  },
  {
    "context": "Editor && extension == md",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-p": "markdown::OpenPreviewToTheSide",
      "ctrl-p p": "markdown::OpenPreview",
    },
  },
  {
    "context": "Editor && extension == svg",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-p": "svg::OpenPreviewToTheSide",
      "ctrl-p p": "svg::OpenPreview",
    },
  },
  {
    "context": "Editor && extension == css",
    "bindings": {
      "shift-v": ["workspace::SendKeystrokes", "var() left"],
      "shift-l": ["workspace::SendKeystrokes", "light - dark() left"],
    },
  },
  {
    "context": "Editor && ( extension == js || extension == rs )",
    "bindings": {
      "shift-l": [
        "workspace::SendKeystrokes",
        "ctrl-c shift-enter console.log( ' ctrl-v :', ctrl-v ) shift-right ;",
      ],
      "ctrl-shift-b": ["workspace::SendKeystrokes", "ctrl-x /* ctrl-v "], // Temporary: Add block comment
    },
  },
  //--- Picker
  {
    "context": "Picker",
    "bindings": {
      "enter": "menu::Confirm",
    }
  },
  {
    "context": "Picker || menu",
    "bindings": {
      "up": "menu::SelectPrevious",
      "down": "menu::SelectNext",
    },
  },
  //--- Project Panel
  {
    "context": "ProjectPanel > Editor",
    "bindings": {
      "enter": "menu::Confirm"
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "workspace::AddFolderToProject",
      
      // Movement
      "right": "project_panel::ExpandSelectedEntry",
      "left": "project_panel::CollapseSelectedEntry",
      
      // Actions
      "f2": "project_panel::Rename",
      "ctrl-x": "project_panel::Cut",
      "ctrl-c": "project_panel::Copy",
      "ctrl-v": "project_panel::Paste",
      "shift-f": "project_panel::NewFile",
      "shift-d": "project_panel::NewDirectory",
      "ctrl-shift-copy": "workspace::CopyRelativePath",
      "delete": ["project_panel::Delete", { "skip_prompt": false }],
      "shift-delete": ["project_panel::Delete", { "skip_prompt": true }],
      "ctrl-shift-enter": "workspace::OpenWithSystem",
      
      "shift-up": "menu::SelectPrevious",
      "shift-down": "menu::SelectNext",
      
      "escape": "menu::Cancel",
      "space": "project_panel::Open",
      "enter": "project_panel::OpenPermanent",
      "ctrl-f": "project_panel::NewSearchInDirectory",
    },
  },
  //--- Welcome
  {
    "context": "Welcome",
    "bindings": {
      "down": "menu::SelectNext",
      "up": "menu::SelectPrevious"
    }
  },
  //--- AgentPanel
  {
    "context": "AgentPanel && text_thread > Editor",
    "bindings": {
      "ctrl-,": "agent::OpenSettings",
      "alt-enter": "assistant::Assist"
    }
  },
  //--- Terminal
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-c": "terminal::Copy",
      "ctrl-v": "terminal::Paste",
      "ctrl-s": ["terminal::SendKeystroke", "ctrl-s"],
      "ctrl-e": ["terminal::SendKeystroke", "ctrl-e"],
      "ctrl-w": ["terminal::SendKeystroke", "ctrl-w"],
      "ctrl-shift-c": ["terminal::SendKeystroke", "ctrl-c"],
      "ctrl-shift-v": ["terminal::SendKeystroke", "ctrl-v"],
    },
  },
  {
    "context": "Terminal && vi_mode",
    "bindings": {
      "escape": "terminal::ToggleViMode",
      "ctrl-c": [ "action::Sequence", ["terminal::Copy", "terminal::ToggleViMode"] ],
    },
  },
  {
    "context": "Terminal && !vi_mode",
    "bindings": {
      "ctrl-c": "terminal::Copy",
      "shift-v": "terminal::ToggleViMode",
    },
  },
]
