{
  "Log into the console": {
    "prefix": "lg",
    "body": ["console.info(\"${1:var}:\", ${1:var});$0"],
    "description": "Logs to console"
  },
  "Make a class": {
    "prefix": "cl",
    "body": [
      "export class ${1:ClassName} {",
      "  constructor(${2:args}) {",
      "    $0",
      "  }",
      "}"
    ],
    "description": "Creates a class with a constructor and a method"
  },
  "Makes arrow": {
    "prefix": "ar",
    "body": [
      "(${2:args}) => { $0 }"
    ],
    "description": "Creates an arrow function"
  },
  "Makes function": {
    "prefix": "fn",
    "body": [
      "function ${1:funcName}(${2:args}) {",
      "  $0",
      "}"
    ],
    "description": "Creates a function"
  },
  "Makes async function": {
    "prefix": "as",
    "body": [
      "async function ${1:funcName}(${2:args}) {",
      "  $0",
      "}"
    ],
    "description": "Creates an async function"
  },
  "document": {
    "prefix": "doc",
    "body": ["document"]
  }
}
